# Embr API - Environment Variables Template
# Copy this file to .env and fill in your actual values

NODE_ENV=development
PORT=3003
API_URL=http://localhost:3003
WEB_URL=http://localhost:3004
MOBILE_URL=http://localhost:8081
COOKIE_SECURE=true

# Database
# The API connects as embr_app (least-privilege, subject to RLS).
# Prisma migrations use the embr superuser (DIRECT_URL, bypasses RLS).
# Both roles are created by docker/postgres/init.sql on first container start.
# Pooled production example (adjust for your host): append e.g. ?connection_limit=10&pool_timeout=20
DATABASE_URL="postgresql://embr_app:<app_password>@localhost:5433/embr"
DIRECT_URL="postgresql://embr:<superuser_password>@localhost:5433/embr"

# Redis (Docker Compose: port 6380, password embr_redis_password)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@localhost:6380
REDIS_TTL_SOCKET=300
REDIS_TTL_TYPING=30

# In-memory cache fallback (Redis errors / missing): max LRU entries before eviction (default 5000).
# CACHE_IN_MEMORY_MAX_KEYS=5000

# JWT - Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3003/v1/auth/google/callback

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_URL=

# Mux Video Processing
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_
PLATFORM_FEE_PERCENTAGE=10

# Email (MailHog for development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@embr.local

# Application URLs - Used in OAuth callbacks and email templates
FRONTEND_URL=http://localhost:3004
APP_URL=http://localhost:3003

# Frontend URLs - Used in OAuth callbacks and email templates
FRONTEND_URL=http://localhost:3004
APP_URL=http://localhost:3003

# CORS
ALLOWED_ORIGINS=http://localhost:3004,http://localhost:8081

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Messaging Rate Limiting
MESSAGING_RATE_LIMIT_ENABLED=true
MESSAGING_RATE_LIMIT_WINDOW=1000
MESSAGING_RATE_LIMIT_MAX=50
MESSAGING_RATE_LIMIT_BURST=10

# Real-time Messaging Rate Limiting
MESSAGING_RATE_LIMIT_ENABLED=true
MESSAGING_RATE_LIMIT_WINDOW=60
MESSAGING_RATE_LIMIT_MAX=50
MESSAGING_RATE_LIMIT_BURST=10
# When true (default), message send rate limits use Redis fixed windows when Redis is healthy (multi-instance). Set false to always use in-process token buckets.
MESSAGING_RATE_LIMIT_REDIS=true

# Redis TTL Settings (in seconds)
REDIS_TTL_SOCKET=300
REDIS_TTL_TYPING=10

# File Upload
MAX_FILE_SIZE=104857600
MAX_VIDEO_DURATION=180

# Observability / Error Tracking (Optional)
# When set, errors are reported via @sentry/nestjs (see src/instrument.ts).
SENTRY_DSN=
# Optional trace sampling 0–1 when SENTRY_DSN is set (default 0.1).
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging — LOG_FORMAT=json emits one JSON object per line for log aggregators.
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Swagger Documentation
ENABLE_SWAGGER=true
SWAGGER_PATH=/docs
