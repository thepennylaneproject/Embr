# Embr Web - Environment Variables Template
# Copy this file to .env.local and fill in your values

# ── Required ────────────────────────────────────────────────────────────────
# Base URL of the Embr API — the app cannot make any API calls without this.
NEXT_PUBLIC_API_URL=http://localhost:3003/api # pragma: allowlist secret

# WebSocket server URL for real-time messaging.
NEXT_PUBLIC_WS_URL=http://localhost:3003

# Production Content-Security-Policy connect-src is built from these URLs (plus Stripe).

# Optional: comma-separated image hostnames for next/image. In production, when set,
# Next.js drops broad S3/CloudFront wildcards and only allows these hosts (plus static CDNs).
# NEXT_PUBLIC_IMAGE_ALLOWED_HOSTS=cdn.example.com,media.example.com

# ── Recommended ─────────────────────────────────────────────────────────────
# Public URL of this web app (canonical links, OAuth redirects).
NEXT_PUBLIC_WEB_URL=http://localhost:3004 # pragma: allowlist secret

# Stripe publishable key — required for checkout and tip/payout UIs.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Google OAuth client ID — required for "Sign in with Google".
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Optional ─────────────────────────────────────────────────────────────────
# Google Analytics measurement ID.
NEXT_PUBLIC_GA_ID=

# Sentry DSN for client-side error tracking.
NEXT_PUBLIC_SENTRY_DSN=

# Music phase-2 (discovery, nav, composer). In production builds, omit or set "false"
# until launch; development defaults to enabled when unset.
NEXT_PUBLIC_FEATURE_MUSIC_PHASE2=

# Set to "true" to enable demo/safe mode in the marketplace checkout page
# (skips real Stripe charges — useful for demos and staging environments).
NEXT_PUBLIC_DEMO_SAFE_MODE=
